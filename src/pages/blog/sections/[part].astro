---
import { getCollection } from "astro:content";
import PartTabs from "@/components/blog/PartTabs.astro";
import PostList from "@/components/blog/PostList.astro";
import Container from "@/components/ui/Container.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { filterByPart, filterPublished, sortByDateDesc } from "@/lib/content";
import { getPartLabel, PART_IDS, type PartId } from "@/lib/taxonomy";

export function getStaticPaths() {
  return PART_IDS.map((part) => ({
    params: { part },
    props: { part },
  }));
}

const members = await getCollection("members");
const allPosts = sortByDateDesc(filterPublished(await getCollection("blog")), "publishedAt");
const currentPart = Astro.props.part as PartId;
const posts = filterByPart(allPosts, currentPart);
const partLabel = getPartLabel(currentPart);
---

<BaseLayout
  title={`${partLabel} Tech Blog`}
  description={`UMC PRODUCT ${partLabel} 파트 기술 블로그 목록입니다.`}
>
  <Container class="py-20 max-[760px]:py-12">
    <SectionHeader
      eyebrow="Tech Blog"
      title={`${partLabel} 기술 블로그`}
      description={`${partLabel} 파트에서 하는 고민과 그 결정들을 공유합니다.`}
    />

    <PartTabs currentPart={currentPart} />

    <PostList
      posts={posts}
      members={members}
      emptyTitle={`${partLabel} 글을 준비 중이에요.`}
      emptyDescription="이 파트의 고민과 결정들이 정리되면 이곳에 표시됩니다."
    />
  </Container>
</BaseLayout>
