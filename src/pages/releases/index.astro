---
import { getCollection } from "astro:content";
import ReleasePageHeader, {
  RELEASE_PAGE_DESCRIPTION,
  RELEASE_PAGE_TITLE,
} from "@/components/releases/ReleasePageHeader.astro";
import ReleaseList from "@/components/releases/ReleaseList.astro";
import Container from "@/components/ui/Container.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { filterPublished, sortByDateDesc } from "@/lib/content";

const releases = sortByDateDesc(
  filterPublished(await getCollection("releases")),
  "releasedAt",
);
---

<BaseLayout title={RELEASE_PAGE_TITLE} description={RELEASE_PAGE_DESCRIPTION}>
  <Container class="py-20 max-[760px]:py-12">
    <ReleasePageHeader />
    <ReleaseList
      releases={releases}
      emptyTitle="릴리즈 노트를 준비 중이에요."
      emptyDescription="배포 맥락과 변경 사항이 정리되면 이곳에 표시됩니다."
    />
  </Container>
</BaseLayout>
