---
import ActionModalContent from "@/components/ui/ActionModalContent.astro";
import {
  REGISTER_REQUIRED_LOGIN_MODAL_CLOSE_ATTRS,
  REGISTER_REQUIRED_NOTICE,
} from "@/lib/auth/registerRequiredNotice";

const notice = {
  title: REGISTER_REQUIRED_NOTICE.title,
  description: REGISTER_REQUIRED_NOTICE.description,
  type: REGISTER_REQUIRED_NOTICE.type,
  primaryLabel: REGISTER_REQUIRED_NOTICE.primaryLabel,
  primaryHref: REGISTER_REQUIRED_NOTICE.primaryHref,
  secondaryLabel: REGISTER_REQUIRED_NOTICE.secondaryLabel,
  secondaryAttrs: REGISTER_REQUIRED_LOGIN_MODAL_CLOSE_ATTRS,
};
---

<ActionModalContent
  {...notice}
/>
