---
type Props = {
  title: string;
  description?: string;
};

const { title, description = "" } = Astro.props;

const shareButtonClass =
  "inline-flex size-11 min-h-11 items-center justify-center rounded-full bg-ds-surface text-ds-text-muted transition-colors hover:border-ds-primary hover:bg-ds-primary-soft hover:text-ds-primary-strong";
---

<section
  class="flex items-center justify-end"
  aria-label="공유하기"
  data-content-share
>
  <button
    type="button"
    class={shareButtonClass}
    data-share-button
    data-share-title={title}
    data-share-text={description}
  >
    <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4" fill="none">
      <path
        d="M8.6 10.8 15.4 7m-6.8 6.2 6.8 3.8M7 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm16-6a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm0 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.8"
      />
    </svg>
    <span class="sr-only" data-share-button-label>공유하기</span>
  </button>

  <div
    class="fixed inset-0 z-[80] hidden grid place-items-center bg-[rgba(22,25,25,0.42)] px-5 py-8"
    role="dialog"
    aria-modal="true"
    aria-label="공유"
    data-share-modal
  >
    <section class="relative w-[min(92vw,360px)] max-w-[360px] rounded-[22px] bg-white p-5 shadow-[0_16px_40px_rgba(17,24,39,0.18)] sm:p-6">
      <div class="space-y-1.5">
        <h2 class="text-[1.25rem] leading-tight font-semibold tracking-[-0.01em] text-[#111827]">
          공유하기
        </h2>
        <p class="text-sm leading-6 text-[#6B7280]">
          링크를 복사하거나 카카오톡, QR로 공유하세요.
        </p>
      </div>
      <div
        class="mt-4 rounded-[16px] border border-[#E5E7EB] bg-[#F9FAFB] px-3 py-3"
        data-share-qr-wrap
      >
        <div class="text-[0.8125rem] font-medium leading-5 text-[#111827]">QR 코드로 공유</div>
        <p class="mt-0.5 text-xs leading-5 text-[#6B7280]">
          상대방이 스캔하면 바로 접속할 수 있어요.
        </p>
        <div class="mt-2 flex justify-center">
          <div class="relative grid size-[152px] place-items-center rounded-[12px] bg-white p-2">
            <span
              class="absolute inset-2 grid place-items-center rounded-[10px] bg-[#F3F4F6] text-xs font-medium text-[#6B7280]"
              data-share-qr-loading
            >
              QR 생성 중
            </span>
            <img
              alt="공유 링크 QR 코드"
              class="relative h-[136px] w-[136px] opacity-0 transition-opacity duration-150"
              data-share-qr
              loading="lazy"
            />
          </div>
        </div>
      </div>
      <div class="mt-4 space-y-3">
        <button
          type="button"
          class="flex h-12 w-full items-center justify-center rounded-[14px] bg-[#FEE500] px-4 text-[1rem] font-semibold leading-6 text-[#111827] transition-colors hover:bg-[#F5D800] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#FEE500] focus-visible:ring-offset-2"
          data-share-kakao
          aria-label="카카오톡으로 공유하기"
        >
          <span>카카오톡으로 공유하기</span>
        </button>
        <button
          type="button"
          class="flex h-12 w-full items-center justify-center rounded-[14px] border border-[#E5E7EB] bg-white px-4 text-[1rem] font-medium leading-6 text-[#111827] transition-colors hover:bg-[#F9FAFB] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#111827] focus-visible:ring-offset-2"
          data-share-copy
          aria-label="URL 복사하기"
        >
          <span>URL 복사하기</span>
        </button>
      </div>
    </section>
  </div>

  <span class="sr-only" data-share-status role="status" aria-live="polite"></span>
  <div
    class="pointer-events-none fixed inset-x-0 bottom-5 z-[95] hidden px-4 transition-opacity"
    data-share-toast
    role="status"
    aria-live="polite"
  >
    <div
      class="mx-auto w-full max-w-[360px] rounded-[14px] bg-ds-text-strong px-4 py-3 text-sm text-white shadow-lg"
      data-share-toast-text
    >
    </div>
  </div>
</section>

<script>
  type KakaoShareSdk = {
    isInitialized: () => boolean;
    init: (appKey: string) => void;
    Share?: {
      sendDefault: (options: {
        objectType: "text" | "feed";
        text: string;
        link: {
          webUrl: string;
          mobileWebUrl: string;
        };
        buttons: Array<{
          title: string;
          link: {
            webUrl: string;
            mobileWebUrl: string;
          };
        }>;
      }) => void;
    };
  };

  type ShareWindow = {
    Kakao?: KakaoShareSdk;
  };

  type ShareData = {
    title: string;
    text: string;
    url: string;
  };

  const shareRoots = document.querySelectorAll<HTMLElement>("[data-content-share]");
  const appKey = import.meta.env.PUBLIC_KAKAO_APP_KEY as string | undefined;

  let toastTimeoutId: number | null = null;

  function generateQRCodeImageSrc(url: string, size = 136): string {
    return `https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(url)}`;
  }

  function setStatusMessage(status: HTMLElement | null, message: string): void {
    if (status) {
      status.textContent = message;
    }
  }

  function showToast(toastWrap: HTMLElement | null, toastText: HTMLElement | null, message: string): void {
    if (!toastWrap || !toastText) {
      return;
    }

    toastText.textContent = message;
    toastWrap.classList.remove("hidden");

    if (toastTimeoutId !== null) {
      window.clearTimeout(toastTimeoutId);
    }
    toastTimeoutId = window.setTimeout(() => {
      toastWrap.classList.add("hidden");
      toastTimeoutId = null;
    }, 1800);
  }

  function buildShareData(button: HTMLButtonElement): ShareData {
    return {
      title: button.dataset.shareTitle || document.title,
      text: button.dataset.shareText || "",
      url: window.location.href,
    };
  }

  async function copyShareUrl(url: string, status: HTMLElement | null): Promise<void> {
    await navigator.clipboard.writeText(url);
    setStatusMessage(status, "링크가 클립보드에 복사되었습니다.");
  }

  function getKakaoSdk(): KakaoShareSdk | undefined {
    return (window as unknown as ShareWindow).Kakao;
  }

  function ensureKakaoSdk(appKeyOverride: string | undefined): void {
    const kakaoSdk = getKakaoSdk();

    if (!kakaoSdk) {
      throw new Error("카카오 SDK가 로드되지 않았습니다.");
    }

    if (!kakaoSdk.Share || typeof kakaoSdk.Share.sendDefault !== "function") {
      throw new Error("카카오 공유 기능이 지원되지 않습니다.");
    }

    if (!appKeyOverride) {
      throw new Error("카카오 앱키가 설정되지 않았습니다.");
    }

    if (!kakaoSdk.isInitialized()) {
      kakaoSdk.init(appKeyOverride);
    }
  }

  function shareWithKakao(data: ShareData, status: HTMLElement | null): void {
    ensureKakaoSdk(appKey);
    getKakaoSdk()!.Share!.sendDefault({
      objectType: "text",
      text: data.text || data.title,
      link: {
        webUrl: data.url,
        mobileWebUrl: data.url,
      },
      buttons: [
        {
          title: "내용 보기",
          link: {
            webUrl: data.url,
            mobileWebUrl: data.url,
          },
        },
      ],
    });
    setStatusMessage(status, "카카오톡 공유 화면을 열었습니다.");
  }

  for (const root of shareRoots) {
    const button = root.querySelector<HTMLButtonElement>("[data-share-button]");
    const status = root.querySelector<HTMLElement>("[data-share-status]");
    const modal = root.querySelector<HTMLElement>("[data-share-modal]");
    const copyButton = root.querySelector<HTMLButtonElement>("[data-share-copy]");
    const kakaoButton = root.querySelector<HTMLButtonElement>("[data-share-kakao]");
    const qrImage = root.querySelector<HTMLImageElement>("[data-share-qr]");
    const qrWrap = root.querySelector<HTMLDivElement>("[data-share-qr-wrap]");
    const qrLoading = root.querySelector<HTMLElement>("[data-share-qr-loading]");
    const toast = root.querySelector<HTMLElement>("[data-share-toast]");
    const toastText = root.querySelector<HTMLElement>("[data-share-toast-text]");

    if (
      !button ||
      !modal ||
      !copyButton ||
      !kakaoButton ||
      !qrImage ||
      !qrWrap ||
      !qrLoading
    ) {
      continue;
    }

    const shareButton = button;
    const shareModal = modal;
    const shareCopyButton = copyButton;
    const shareKakaoButton = kakaoButton;
    const shareQrImage = qrImage;
    const shareQrWrap = qrWrap;
    const shareQrLoading = qrLoading;

    let onEscapeKey: ((event: KeyboardEvent) => void) | null = null;

    function setQrLoading(isLoading: boolean, message = "QR 생성 중"): void {
      shareQrLoading.textContent = message;
      shareQrLoading.classList.toggle("hidden", !isLoading);
      shareQrImage.classList.toggle("opacity-0", isLoading);
    }

    function showModal(): void {
      const shareData = buildShareData(shareButton);
      shareModal.classList.remove("hidden");
      setStatusMessage(status, `${shareData.title}을(를) 공유합니다.`);
      shareKakaoButton.focus();
      onEscapeKey = (event): void => {
        if (event.key === "Escape") {
          hideModal();
        }
      };
      document.addEventListener("keydown", onEscapeKey);
      shareQrImage.removeAttribute("src");
      setQrLoading(true);
      shareQrImage.src = generateQRCodeImageSrc(shareData.url, 136);
      shareQrWrap.classList.remove("hidden");
    }

    function hideModal(): void {
      shareModal.classList.add("hidden");
      if (onEscapeKey) {
        document.removeEventListener("keydown", onEscapeKey);
        onEscapeKey = null;
      }
      if (toastTimeoutId !== null) {
        window.clearTimeout(toastTimeoutId);
        toastTimeoutId = null;
      }
      shareQrImage.removeAttribute("src");
      setQrLoading(true);
      setStatusMessage(status, "");
      if (toast) {
        toast.classList.add("hidden");
      }
    }

    shareQrImage.addEventListener("load", () => {
      setQrLoading(false);
    });

    shareQrImage.addEventListener("error", () => {
      setQrLoading(true, "QR을 불러오지 못했습니다");
      setStatusMessage(status, "QR 코드를 불러오지 못했습니다.");
    });

    shareButton.addEventListener("click", () => {
      if (status) {
        status.textContent = "";
      }
      showModal();
    });

    shareModal.addEventListener("click", (event) => {
      if (event.target === shareModal) {
        hideModal();
      }
    });

    shareCopyButton.addEventListener("click", async () => {
      const shareData = buildShareData(shareButton);
      try {
        await copyShareUrl(shareData.url, status);
        setStatusMessage(status, "링크가 클립보드에 복사되었습니다.");
        showToast(toast, toastText, "링크가 클립보드에 복사되었습니다.");
      } catch (error) {
        if (error instanceof DOMException && error.name === "NotAllowedError") {
          setStatusMessage(status, "클립보드 접근이 거부되었습니다.");
          showToast(toast, toastText, "클립보드 접근이 거부되었습니다.");
          return;
        }
        setStatusMessage(status, "클립보드 복사에 실패했습니다.");
        showToast(toast, toastText, "클립보드 복사에 실패했습니다.");
      }
    });

    shareKakaoButton.addEventListener("click", () => {
      try {
        const shareData = buildShareData(shareButton);
        shareWithKakao(shareData, status);
        showToast(toast, toastText, "카카오톡 공유 화면을 열었습니다.");
      } catch (error) {
        const message =
          error instanceof Error ? error.message : "카카오톡 공유를 시작하지 못했습니다.";
        setStatusMessage(status, message);
        showToast(toast, toastText, message);
      }
    });

    document.addEventListener("click", (event) => {
      if (!shareModal.classList.contains("hidden") && !root.contains(event.target as Node)) {
        hideModal();
      }
    });
  }
</script>
