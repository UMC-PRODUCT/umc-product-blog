---
type ActionType = "default" | "confirm" | "destructive";
type ActionAttrs = Record<string, string | boolean | undefined>;

type Props = {
  title: string;
  description?: string;
  type?: ActionType;
  primaryLabel: string;
  primaryHref?: string;
  primaryAttrs?: ActionAttrs;
  secondaryLabel?: string;
  secondaryHref?: string;
  secondaryAttrs?: ActionAttrs;
};

const {
  title,
  description,
  type = "confirm",
  primaryLabel,
  primaryHref,
  primaryAttrs = {},
  secondaryLabel,
  secondaryHref,
  secondaryAttrs = {},
} = Astro.props;

const buttonBaseClass =
  "text-label-1-medium inline-flex min-h-12 items-center justify-center rounded-[12px] px-4 transition-colors focus-visible:ring-2 focus-visible:ring-teal-300 focus-visible:ring-offset-2 focus-visible:outline-none";
const defaultButtonClass = `${buttonBaseClass} bg-teal-gray-100 text-teal-gray-800 hover:bg-teal-gray-150`;

const primaryClassByType: Record<ActionType, string> = {
  default: `${buttonBaseClass} bg-teal-gray-900 text-white hover:bg-teal-gray-800`,
  confirm: `${buttonBaseClass} bg-teal-500 text-white hover:bg-teal-600`,
  destructive: `${buttonBaseClass} bg-error-500 text-white hover:bg-error-600`,
};

const hasSecondary = Boolean(secondaryLabel);
---

<div class="grid gap-5">
  <div class="grid gap-2 text-left">
    <h2 id="action-modal-title" class="m-0 text-heading-6-semibold text-teal-gray-900">{title}</h2>
    {description && <p class="m-0 whitespace-pre-line text-body-2-regular text-teal-gray-600">{description}</p>}
  </div>
  <div class:list={["grid gap-2", hasSecondary ? "grid-cols-2" : "grid-cols-1"]}>
    {
      hasSecondary && (
        secondaryHref ? (
          <a class={defaultButtonClass} href={secondaryHref} {...secondaryAttrs}>
            {secondaryLabel}
          </a>
        ) : (
          <button class={defaultButtonClass} type="button" {...secondaryAttrs}>
            {secondaryLabel}
          </button>
        )
      )
    }
    {
      primaryHref ? (
        <a class={primaryClassByType[type]} href={primaryHref} {...primaryAttrs}>
          {primaryLabel}
        </a>
      ) : (
        <button class={primaryClassByType[type]} type="button" {...primaryAttrs}>
          {primaryLabel}
        </button>
      )
    }
  </div>
</div>
