---
import ActionModalContent from "./ActionModalContent.astro";

type ActionType = "default" | "confirm" | "destructive";
type ActionModalSize = "small" | "medium" | "large";
type ActionAttrs = Record<string, string | boolean | undefined>;

type Props = {
  title: string;
  description?: string;
  type?: ActionType;
  primaryLabel: string;
  primaryHref?: string;
  primaryAttrs?: ActionAttrs;
  secondaryLabel?: string;
  secondaryHref?: string;
  secondaryAttrs?: ActionAttrs;
  hidden?: boolean;
  dataAttribute?: string;
  size?: ActionModalSize;
};

const {
  title,
  description,
  type = "confirm",
  primaryLabel,
  primaryHref,
  primaryAttrs,
  secondaryLabel,
  secondaryHref,
  secondaryAttrs,
  hidden = true,
  dataAttribute,
  size = "medium",
} = Astro.props;

const dataAttributes = dataAttribute ? { [dataAttribute]: "" } : {};

const sizeClassBySize: Record<ActionModalSize, string> = {
  small: "max-w-[360px]",
  medium: "max-w-[480px]",
  large: "max-w-[720px]",
};
---

<div
  class:list={["fixed inset-0 z-[80] grid place-items-center bg-[rgba(22,25,25,0.42)] p-5", hidden && "hidden"]}
  {...dataAttributes}
>
  <section
    class:list={["w-full rounded-[24px] bg-white px-6 pt-3 pb-5", sizeClassBySize[size]]}
    role="dialog"
    aria-modal="true"
    aria-labelledby="action-modal-title"
  >
    <ActionModalContent
      title={title}
      description={description}
      type={type}
      primaryLabel={primaryLabel}
      primaryHref={primaryHref}
      primaryAttrs={primaryAttrs}
      secondaryLabel={secondaryLabel}
      secondaryHref={secondaryHref}
      secondaryAttrs={secondaryAttrs}
    />
  </section>
</div>
